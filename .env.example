# Copy to .env and fill in. .env is git-ignored and must never be committed.

# NetBox base URL. Two names for the same value:
#   NETBOX_API is read by the Ansible netbox.netbox inventory plugin.
#   NETBOX_URL is used by companion tooling (netbox-ai-ingest).
NETBOX_API=http://localhost:8000
NETBOX_URL=http://localhost:8000

# NetBox API token (read-capable). Never commit the real value.
NETBOX_TOKEN=your-netbox-api-token-here
